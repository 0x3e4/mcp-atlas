# Copy to zammad.env and fill in. Never commit real secrets.

# --- Zammad instance (required) ---
# The Zammad base URL (HTTPS). No /api suffix.
ZAMMAD_BASE_URL=https://zammad.example.com
# API token (Profile -> Token Access). For writes the token needs ticket.agent permission.
ZAMMAD_TOKEN=

# --- writes (opt-in) ---
# Leave false for a read-only server. Set true to enable the write tools
# (add_note, update_ticket, create_ticket). Requires a token with ticket.agent permission.
ZAMMAD_ALLOW_WRITE=false

# --- transport ---
# stdio (default, for Claude Code) | streamable-http (always-on HTTP server)
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000

# --- TLS ---
# For a self-signed / internal-CA instance, point ZAMMAD_CA_BUNDLE at the CA PEM,
# or (lab only) set ZAMMAD_VERIFY_SSL=false.
ZAMMAD_VERIFY_SSL=true
ZAMMAD_CA_BUNDLE=

# --- advanced / optional ---
# httpx request timeout in seconds.
ZAMMAD_TIMEOUT=30
# Default page size for list results (per_page; capped at 200 here).
ZAMMAD_MAX_ROWS=50
