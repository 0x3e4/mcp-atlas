# Copy to prtg.env and fill in. Never commit real secrets.

# --- PRTG server (required) ---
# The PRTG base URL (HTTPS). No /api suffix.
PRTG_BASE_URL=https://prtg.example.com

# --- auth (pick ONE) ---
# Preferred: a read-only API key (Setup -> Account Settings -> API Keys; PRTG 23.x+).
PRTG_API_TOKEN=
# Legacy fallback: username + passhash (get the hash from
#   /api/getpasshash.htm?username=<u>&password=<p>, or Account Settings -> Show Passhash).
PRTG_USERNAME=
PRTG_PASSHASH=
# Or username + password instead of passhash (less preferred):
# PRTG_PASSWORD=

# --- transport ---
# stdio (default, for Claude Code) | streamable-http (always-on HTTP server)
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000

# --- TLS ---
# PRTG ships a self-signed cert by default. Point PRTG_CA_BUNDLE at the CA PEM,
# or (lab only) set PRTG_VERIFY_SSL=false.
PRTG_VERIFY_SSL=true
PRTG_CA_BUNDLE=

# --- advanced / optional ---
# httpx request timeout in seconds.
PRTG_TIMEOUT=30
# Default row cap for list results (PRTG 'count'; capped at 5000 here).
PRTG_MAX_ROWS=200
