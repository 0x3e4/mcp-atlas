# Copy to azure-devops.env and fill in. Never commit real secrets.

# --- Azure DevOps Server (on-prem) — required ---
# The COLLECTION URL (HTTPS). On-prem includes the collection (and often a /tfs/ virtual dir).
# Examples: https://devops.contoso.com/DefaultCollection   |   https://devops.contoso.com/tfs/DefaultCollection
AZDO_BASE_URL=https://devops.contoso.com/DefaultCollection
# Personal Access Token with READ scopes (Code, Work Items, Build, Project & Team).
AZDO_PAT=

# --- api version (match your server) ---
# Azure DevOps Server 2019 -> 5.0 | 2020 -> 6.0 | 2022 -> 7.0 (2022.1 -> 7.1). TFS 2018 -> 4.1.
AZDO_API_VERSION=7.0

# --- scope ---
# Optional default project for project-scoped tools (so you can omit project=...).
AZDO_PROJECT=

# --- writes (opt-in) ---
# Leave false for a read-only server. Set true to enable the work-item and wiki WRITE tools
# (create_work_item, update_work_item, create_or_update_wiki_page). Requires a PAT with the
# matching write scopes (Work Items 'Read & write', Wiki 'Read & write').
AZDO_ALLOW_WRITE=false

# --- transport ---
# stdio (default, for Claude Code) | streamable-http (always-on HTTP server)
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000

# --- TLS ---
# On-prem servers often use an internal CA. Point AZDO_CA_BUNDLE at the CA PEM,
# or (lab only) set AZDO_VERIFY_SSL=false.
AZDO_VERIFY_SSL=true
AZDO_CA_BUNDLE=

# --- advanced / optional ---
# httpx request timeout in seconds.
AZDO_TIMEOUT=30
# Default row cap for shaped (non-full) list results.
AZDO_MAX_ROWS=200
