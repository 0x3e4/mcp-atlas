# Copy to defender.env and fill in. Never commit real secrets.

# --- Entra ID app registration (required) ---
DEFENDER_TENANT_ID=
DEFENDER_CLIENT_ID=
DEFENDER_CLIENT_SECRET=

# --- transport ---
# stdio (default, for Claude Code) | streamable-http (always-on HTTP server)
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000

# --- advanced / optional ---
# Switch to a Gov cloud by overriding these (and LOGIN_BASE_URL):
#   GRAPH_BASE_URL=https://graph.microsoft.us/v1.0
#   LOGIN_BASE_URL=https://login.microsoftonline.us
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
LOGIN_BASE_URL=https://login.microsoftonline.com

# httpx timeout in seconds (hunting queries can run up to ~3 minutes).
DEFENDER_TIMEOUT=180

# Default row cap for shaped (non-full) results.
DEFENDER_MAX_ROWS=200
