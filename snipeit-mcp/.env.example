# Copy to snipeit.env and fill in. Never commit real secrets.

# --- Snipe-IT instance (required) ---
# The Snipe-IT base URL (HTTPS). No /api suffix.
SNIPEIT_BASE_URL=https://snipe.example.com
# Personal API token (Account -> Manage API Keys -> Create New Token). Inherits the user's permissions.
SNIPEIT_TOKEN=

# --- writes (opt-in) ---
# Leave false for a read-only server. Set true to enable the write tools
# (checkout_asset, checkin_asset, update_asset, create_asset, audit_asset). The token's user must
# also hold the matching Snipe-IT permissions (Checkout/Edit/Create/Audit assets).
SNIPEIT_ALLOW_WRITE=false

# --- transport ---
# stdio (default, for Claude Code) | streamable-http (always-on HTTP server)
# Optional - compose.yml sets these for the HTTP daemon (and overrides this file). Uncomment only for a manual docker-run HTTP server:
# MCP_TRANSPORT=streamable-http
# MCP_HOST=0.0.0.0
# MCP_PORT=8000

# --- TLS ---
# For a self-signed / internal-CA instance, point SNIPEIT_CA_BUNDLE at the CA PEM,
# or (lab only) set SNIPEIT_VERIFY_SSL=false.
SNIPEIT_VERIFY_SSL=true
SNIPEIT_CA_BUNDLE=

# --- advanced / optional ---
# httpx request timeout in seconds.
SNIPEIT_TIMEOUT=30
# Default page size for list results (limit; Snipe-IT caps at 500).
SNIPEIT_MAX_ROWS=50
