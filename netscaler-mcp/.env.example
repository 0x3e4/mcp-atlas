# Copy to netscaler.env and fill in. Never commit real secrets.

# --- NetScaler ADC appliance (required) ---
# The appliance management URL: NSIP, or the HA management VIP / primary node IP. No /nitro suffix.
NETSCALER_BASE_URL=https://10.0.0.10
# A system user bound to the built-in 'readonlypolicy' command policy.
NETSCALER_USER=
NETSCALER_PASSWORD=

# --- auth ---
# session (default): log in once, cache the NITRO_AUTH_TOKEN cookie, re-login on expiry.
# stateless: send X-NITRO-USER / X-NITRO-PASS on every request (no session slot held).
NETSCALER_AUTH_MODE=session
# Session lifetime (seconds) requested at login (session mode only).
NETSCALER_SESSION_TIMEOUT=900

# --- transport ---
# stdio (default, for Claude Code) | streamable-http (always-on HTTP server)
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000

# --- TLS ---
# Appliances ship self-signed certs. Point NETSCALER_CA_BUNDLE at the appliance CA PEM,
# or (lab only) set NETSCALER_VERIFY_SSL=false.
NETSCALER_VERIFY_SSL=true
NETSCALER_CA_BUNDLE=

# --- advanced / optional ---
# httpx request timeout in seconds.
NETSCALER_TIMEOUT=30
# Default row cap for shaped (non-full) list results.
NETSCALER_MAX_ROWS=200
