# Copy to template.env and fill in. Never commit real secrets.

# --- upstream API (required) ---
TEMPLATE_BASE_URL=https://api.example.com
TEMPLATE_API_KEY=

# --- transport ---
# stdio (default, for Claude Code) | streamable-http (always-on HTTP server)
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000

# --- advanced / optional ---
# httpx request timeout in seconds.
TEMPLATE_TIMEOUT=30

# Default row cap for shaped (non-full) results.
TEMPLATE_MAX_ROWS=200

# TLS verification. For a self-signed upstream, point TEMPLATE_CA_BUNDLE at the CA PEM file,
# or (lab only) set TEMPLATE_VERIFY_SSL=false.
TEMPLATE_VERIFY_SSL=true
TEMPLATE_CA_BUNDLE=
