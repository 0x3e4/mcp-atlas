# ---------------------------------------------------------------------------
# Wazuh MCP server configuration. Copy to "wazuh.env" and fill in your values.
# Pass it to the container with:  docker run --env-file wazuh.env ...
# ---------------------------------------------------------------------------

# --- Wazuh Manager REST API (agents, inventory, rules, SCA, status) ---
WAZUH_MANAGER_URL=https://wazuh.example.com:55000
WAZUH_USER=wazuh-wui
WAZUH_PASS=changeme

# --- Wazuh Indexer / OpenSearch (alerts, archives, vulnerabilities) ---
WAZUH_INDEXER_URL=https://wazuh.example.com:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASS=changeme

# --- TLS ---
# Verify upstream certificates. Set to false ONLY for trusted lab/self-signed setups.
WAZUH_VERIFY_SSL=true
# Path (inside the container) to the Wazuh root CA, used when WAZUH_VERIFY_SSL=true.
# Mount it in, e.g.  -v /etc/wazuh-indexer/certs/root-ca.pem:/certs/root-ca.pem:ro
# WAZUH_CA_BUNDLE=/certs/root-ca.pem

# --- MCP transport ---
# "stdio" (default; launched per-session by Claude Code) or "streamable-http".
# Optional - compose.yml sets these for the HTTP daemon (and overrides this file). Uncomment only for a manual docker-run HTTP server:
# MCP_TRANSPORT=streamable-http
# Only used when MCP_TRANSPORT=streamable-http:
# MCP_HOST=0.0.0.0
# MCP_PORT=8000

# --- Advanced / optional overrides (defaults shown) ---
# WAZUH_TIME_FIELD=timestamp
# WAZUH_ALERTS_INDEX=wazuh-alerts-*
# WAZUH_ARCHIVES_INDEX=wazuh-archives-*
# WAZUH_VULNS_INDEX=wazuh-states-vulnerabilities-*
# WAZUH_TIMEOUT=30
