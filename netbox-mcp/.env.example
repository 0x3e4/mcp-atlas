# Copy to netbox.env and fill in. Never commit real secrets.

# --- NetBox instance (required) ---
# The NetBox base URL (HTTPS). No /api suffix.
NETBOX_BASE_URL=https://netbox.example.com
# API token (user profile -> API Tokens). Use a READ-ONLY token (uncheck "write enabled").
# v1 token -> sent as "Token <token>"; v2 token "nbt_..." (NetBox 4.5+) -> sent as "Bearer".
NETBOX_TOKEN=

# --- transport ---
# stdio (default, for Claude Code) | streamable-http (always-on HTTP server)
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000

# --- TLS ---
# For a self-signed / internal-CA instance, point NETBOX_CA_BUNDLE at the CA PEM,
# or (lab only) set NETBOX_VERIFY_SSL=false.
NETBOX_VERIFY_SSL=true
NETBOX_CA_BUNDLE=

# --- advanced / optional ---
# httpx request timeout in seconds.
NETBOX_TIMEOUT=30
# Default page size for list results (limit; NetBox MAX_PAGE_SIZE caps at 1000).
NETBOX_MAX_ROWS=50
