# Copy to fortigate.env and fill in. Never commit real secrets.

# --- FortiGate appliance (required) ---
# The management URL (HTTPS). No /api/v2 suffix. For an HA cluster, point at the management IP.
FORTIGATE_BASE_URL=https://192.0.2.1
# API token of a REST API admin whose access profile is read-only (see README).
FORTIGATE_API_TOKEN=

# --- scope ---
# VDOM to query by default ("root" on single-VDOM boxes). Tools can override per call.
FORTIGATE_VDOM=root

# --- transport ---
# stdio (default, for Claude Code) | streamable-http (always-on HTTP server)
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000

# --- TLS ---
# Appliances ship self-signed certs. Point FORTIGATE_CA_BUNDLE at the appliance CA PEM,
# or (lab only) set FORTIGATE_VERIFY_SSL=false.
FORTIGATE_VERIFY_SSL=true
FORTIGATE_CA_BUNDLE=

# --- advanced / optional ---
# httpx request timeout in seconds.
FORTIGATE_TIMEOUT=30
# Default row cap for shaped (non-full) list results.
FORTIGATE_MAX_ROWS=200
