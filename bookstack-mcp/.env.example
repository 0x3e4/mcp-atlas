# Copy to bookstack.env and fill in. Never commit real secrets.

# --- BookStack instance (required) ---
# The BookStack base URL (HTTPS). No /api suffix.
BOOKSTACK_BASE_URL=https://docs.example.com
# API token of a user with the 'Access System API' permission (Profile -> API Tokens).
BOOKSTACK_TOKEN_ID=
BOOKSTACK_TOKEN_SECRET=

# --- transport ---
# stdio (default, for Claude Code) | streamable-http (always-on HTTP server)
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000

# --- TLS ---
# For a self-signed / internal-CA instance, point BOOKSTACK_CA_BUNDLE at the CA PEM,
# or (lab only) set BOOKSTACK_VERIFY_SSL=false.
BOOKSTACK_VERIFY_SSL=true
BOOKSTACK_CA_BUNDLE=

# --- advanced / optional ---
# httpx request timeout in seconds.
BOOKSTACK_TIMEOUT=30
# Default page size for list results (BookStack caps 'count' at 500).
BOOKSTACK_MAX_ROWS=100
