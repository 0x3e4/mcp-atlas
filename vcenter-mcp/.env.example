# Copy to vcenter.env and fill in. Never commit real secrets.

# --- vCenter Server (required) ---
# The vCenter base URL (HTTPS). No /api suffix. Uses the new /api (vSphere 7.0u2+/8.0).
VCENTER_BASE_URL=https://vcenter.example.com
# vCenter SSO credentials (a read-only role is recommended).
VCENTER_USERNAME=readonly@vsphere.local
VCENTER_PASSWORD=

# --- transport ---
# stdio (default, for Claude Code) | streamable-http (always-on HTTP server)
# Optional - compose.yml sets these for the HTTP daemon (and overrides this file). Uncomment only for a manual docker-run HTTP server:
# MCP_TRANSPORT=streamable-http
# MCP_HOST=0.0.0.0
# MCP_PORT=8000

# --- TLS ---
# vCenter ships a self-signed cert by default. Point VCENTER_CA_BUNDLE at the CA PEM,
# or (lab only) set VCENTER_VERIFY_SSL=false.
VCENTER_VERIFY_SSL=true
VCENTER_CA_BUNDLE=

# --- advanced / optional ---
# httpx request timeout in seconds.
VCENTER_TIMEOUT=30
# Client-side cap for list results (vCenter has no pagination; narrow with filters).
VCENTER_MAX_ROWS=200
